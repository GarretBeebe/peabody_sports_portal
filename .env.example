# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=sports_portal
POSTGRES_USER=sports
POSTGRES_PASSWORD=changeme

# ── Flask ─────────────────────────────────────────────────────────────────────
# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-32-random-bytes
# Set to "development" for local HTTP dev (disables SESSION_COOKIE_SECURE)
FLASK_ENV=production

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_FROM=sports@school.org
# Leave blank if the relay does not require auth
SMTP_USER=
SMTP_PASSWORD=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Hour (0-23) in server local time to run the daily email job
SCHEDULER_HOUR=7

# ── Session ───────────────────────────────────────────────────────────────────
PERMANENT_SESSION_LIFETIME_HOURS=8

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
